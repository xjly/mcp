{
  "mcpServers": {
    "neo4j": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/xjly/mcp#subdirectory=graph",
        "neo4j-mcp"
      ],
      "env": {
        "NEO4J_URI": "bolt://xxxx:7687",
        "NEO4J_USERNAME": "your_username",
        "NEO4J_PASSWORD": "your_password"
      }
    }
  }
}
